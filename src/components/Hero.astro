---
---

<header class="hero">
  <div class="hero-left">
    <div class="logo">
      <span class="logo-b">B</span>
      <span class="logo-text">MINIMALISTA</span>
    </div>
  </div>
  <div class="hero-right">
    <h1 class="brand-name">Minimalista by<br/>Bryan Muñiz</h1>
    <p class="hero-subtitle">Calculadora de intercambio</p>
  </div>
</header>

<style>
  .hero {
    display: flex;
    align-items: center;
    width: 100%;
    min-height: 140px;
    overflow: hidden;
  }

  .hero-left {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-beige);
    padding: 2rem 3rem;
    min-height: 140px;
    position: relative;
  }

  .hero-left::after {
    content: '';
    position: absolute;
    right: -40px;
    top: 0;
    bottom: 0;
    width: 80px;
    background-color: var(--color-beige);
    border-radius: 0 50% 50% 0;
  }

  .hero-right {
    flex: 1;
    padding: 2rem 3rem;
    background-color: var(--color-cream);
  }

  .logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .logo-b {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    font-weight: 700;
    color: var(--color-dark-brown);
    line-height: 1;
  }

  .logo-text {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--color-dark-brown);
    font-weight: 500;
    margin-top: 0.25rem;
  }

  .brand-name {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    color: var(--color-dark-brown);
    line-height: 1.3;
    font-style: italic;
  }

  .hero-subtitle {
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-dark-brown);
    margin-top: 0.75rem;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    .hero {
      flex-direction: column;
      min-height: auto;
    }

    .hero-left {
      width: 100%;
      min-height: 100px;
      padding: 1.5rem;
    }

    .hero-left::after {
      display: none;
    }

    .hero-right {
      padding: 1.5rem;
      text-align: center;
    }

    .brand-name {
      font-size: 1.5rem;
    }
  }
</style>
