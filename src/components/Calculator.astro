---
import { grupos } from '../lib/foods';
import type { Food } from '../db/schema';

interface Props {
  foods: Food[];
}

const { foods } = Astro.props;

const foodsByGroup: Record<string, Food[]> = {};
for (const grupo of grupos) {
  foodsByGroup[grupo] = foods.filter(f => f.grupo === grupo);
}
---

<section class="calculator" id="calculadora">
  <div class="calculator-container">
    <h2 class="section-title">Tu alimento del menú</h2>

    <div class="card input-card">
      <div class="form-group">
        <label>Filtrar por grupo</label>
        <div class="filter-buttons" id="filter-buttons">
          <button class="filter-btn active" data-filter="all">Todos</button>
          {grupos.map(grupo => (
            <button class="filter-btn" data-filter={grupo}>{grupo}</button>
          ))}
        </div>
      </div>

      <div class="form-group">
        <label>Alimento de tu menú</label>
        <div class="searchable-select" id="food-wrapper">
          <input type="text" class="search-input" id="food-search" placeholder="Buscar alimento..." />
          <button type="button" class="search-clear" id="food-clear" style="display:none;">&times;</button>
          <ul class="search-options" id="food-options"></ul>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="quantity-input">Cantidad de tu menú</label>
          <div class="input-with-unit">
            <input type="number" id="quantity-input" placeholder="0" min="0" step="any" />
            <span class="unit-label" id="unit-label">g</span>
          </div>
        </div>

        <div class="form-group">
          <label>Grupo</label>
          <div class="group-badge" id="group-badge">—</div>
        </div>
      </div>
    </div>

    <div class="divider">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/>
      </svg>
    </div>

    <h2 class="section-title">Opciones de intercambio</h2>

    <div class="card output-card">
      <div class="exchange-section" id="exchange-section-simple">
        <div class="form-group">
          <label>Intercambiar por</label>
          <div class="searchable-select" id="exchange-wrapper">
            <input type="text" class="search-input" id="exchange-search" placeholder="Selecciona un alimento primero..." disabled />
            <button type="button" class="search-clear" id="exchange-clear" style="display:none;">&times;</button>
            <ul class="search-options" id="exchange-options"></ul>
          </div>
        </div>

        <div class="result" id="result-simple" style="display: none;">
          <div class="result-label">Cantidad que puedes comer</div>
          <div class="result-value" id="result-value">—</div>
          <div class="result-unit" id="result-unit"></div>
        </div>
      </div>

      <div class="exchange-section mixed-section" id="exchange-section-mixed" style="display: none;">
        <p class="mixed-info" id="mixed-info"></p>

        <div class="form-group">
          <label id="exchange-label-1">Opción 1 (Proteína - ½ ración)</label>
          <div class="searchable-select" id="mixed1-wrapper">
            <input type="text" class="search-input" id="mixed1-search" placeholder="Selecciona..." disabled />
            <button type="button" class="search-clear" id="mixed1-clear" style="display:none;">&times;</button>
            <ul class="search-options" id="mixed1-options"></ul>
          </div>
        </div>

        <div class="result" id="result-mixed-1" style="display: none;">
          <div class="result-label" id="result-label-1">Cantidad</div>
          <div class="result-value" id="result-value-1">—</div>
          <div class="result-unit" id="result-unit-1"></div>
        </div>

        <div class="form-group">
          <label id="exchange-label-2">Opción 2 (Hidratos - ½ ración)</label>
          <div class="searchable-select" id="mixed2-wrapper">
            <input type="text" class="search-input" id="mixed2-search" placeholder="Selecciona..." disabled />
            <button type="button" class="search-clear" id="mixed2-clear" style="display:none;">&times;</button>
            <ul class="search-options" id="mixed2-options"></ul>
          </div>
        </div>

        <div class="result" id="result-mixed-2" style="display: none;">
          <div class="result-label" id="result-label-2">Cantidad</div>
          <div class="result-value" id="result-value-2">—</div>
          <div class="result-unit" id="result-unit-2"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ foodsData: foods }}>
  const quantityInput = document.getElementById('quantity-input');
  const unitLabel = document.getElementById('unit-label');
  const groupBadge = document.getElementById('group-badge');
  const resultSimple = document.getElementById('result-simple');
  const resultValue = document.getElementById('result-value');
  const resultUnit = document.getElementById('result-unit');

  const sectionSimple = document.getElementById('exchange-section-simple');
  const sectionMixed = document.getElementById('exchange-section-mixed');
  const mixedInfo = document.getElementById('mixed-info');
  const exchangeLabel1 = document.getElementById('exchange-label-1');
  const exchangeLabel2 = document.getElementById('exchange-label-2');
  const resultMixed1 = document.getElementById('result-mixed-1');
  const resultMixed2 = document.getElementById('result-mixed-2');
  const resultValue1 = document.getElementById('result-value-1');
  const resultValue2 = document.getElementById('result-value-2');
  const resultUnit1 = document.getElementById('result-unit-1');
  const resultUnit2 = document.getElementById('result-unit-2');
  const filterButtons = document.querySelectorAll('.filter-btn');

  const foods = foodsData;

  // --- Searchable select component ---
  function createSearchSelect(wrapperId, searchId, optionsId, clearId, onChange) {
    const wrapper = document.getElementById(wrapperId);
    const input = document.getElementById(searchId);
    const optionsList = document.getElementById(optionsId);
    const clearBtn = document.getElementById(clearId);

    const state = { value: '', items: [], input, optionsList, wrapper, clearBtn, onChange };

    input.addEventListener('input', () => {
      const query = input.value.toLowerCase();
      const filtered = state.items.filter(item => item.label.toLowerCase().includes(query));
      renderOptions(state, filtered);
      optionsList.style.display = 'block';
    });

    input.addEventListener('focus', () => {
      if (input.disabled) return;
      const query = input.value.toLowerCase();
      const filtered = state.items.filter(item => item.label.toLowerCase().includes(query));
      renderOptions(state, filtered);
      optionsList.style.display = 'block';
    });

    clearBtn.addEventListener('mousedown', (e) => {
      e.preventDefault();
      state.value = '';
      state.input.value = '';
      clearBtn.style.display = 'none';
      state.optionsList.style.display = 'none';
      if (state.onChange) state.onChange('');
    });

    document.addEventListener('mousedown', (e) => {
      if (!wrapper.contains(e.target)) {
        optionsList.style.display = 'none';
        if (state.value) {
          input.value = state.value;
        } else {
          input.value = '';
        }
      }
    });

    return state;
  }

  function renderOptions(state, filtered) {
    if (filtered.length === 0) {
      state.optionsList.innerHTML = '<li class="search-option-empty">Sin resultados</li>';
      return;
    }

    state.optionsList.innerHTML = '';
    filtered.forEach((item) => {
      const li = document.createElement('li');
      li.className = 'search-option' + (item.value === state.value ? ' selected' : '');
      li.textContent = item.label;
      li.addEventListener('mousedown', (e) => {
        e.preventDefault();
        state.value = item.value;
        state.input.value = item.label;
        state.optionsList.style.display = 'none';
        state.clearBtn.style.display = 'flex';
        if (state.onChange) state.onChange(state.value);
      });
      state.optionsList.appendChild(li);
    });
  }

  // --- Initialize all searchable selects ---
  const foodSearch = createSearchSelect('food-wrapper', 'food-search', 'food-options', 'food-clear', onFoodSelected);
  const exchangeSearch = createSearchSelect('exchange-wrapper', 'exchange-search', 'exchange-options', 'exchange-clear', () => calculateAndDisplay());
  const mixed1Search = createSearchSelect('mixed1-wrapper', 'mixed1-search', 'mixed1-options', 'mixed1-clear', () => calculateAndDisplay());
  const mixed2Search = createSearchSelect('mixed2-wrapper', 'mixed2-search', 'mixed2-options', 'mixed2-clear', () => calculateAndDisplay());

  // Populate main food search with all items
  let activeFilter = 'all';

  function buildFoodItems(filter) {
    if (filter === 'all') {
      return foods.map(f => ({ value: f.alimento, label: f.alimento, grupo: f.grupo }));
    }
    return foods.filter(f => f.grupo === filter).map(f => ({ value: f.alimento, label: f.alimento, grupo: f.grupo }));
  }

  function refreshFoodList() {
    foodSearch.items = buildFoodItems(activeFilter);
    foodSearch.value = '';
    foodSearch.input.value = '';
    onFoodSelected('');
  }

  refreshFoodList();

  // Filter buttons
  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      filterButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.dataset.filter;
      refreshFoodList();
    });
  });

  // --- Food selection handler ---
  function getSelectedFood() {
    if (!foodSearch.value) return null;
    return foods.find(f => f.alimento === foodSearch.value) || null;
  }

  function onFoodSelected(value) {
    const selectedFood = value ? foods.find(f => f.alimento === value) : null;

    if (!selectedFood) {
      unitLabel.textContent = 'g';
      groupBadge.textContent = '—';
      groupBadge.className = 'group-badge';
      exchangeSearch.input.disabled = true;
      exchangeSearch.items = [];
      exchangeSearch.value = '';
      exchangeSearch.input.value = '';
      exchangeSearch.input.placeholder = 'Selecciona un alimento primero...';
      sectionSimple.style.display = 'block';
      sectionMixed.style.display = 'none';
      resultSimple.style.display = 'none';
      return;
    }

    unitLabel.textContent = selectedFood.unidad;
    groupBadge.textContent = selectedFood.grupo;
    groupBadge.className = 'group-badge badge-' + selectedFood.grupo.toLowerCase().replace(/[^a-z]/g, '');

    if (selectedFood.grupo.startsWith('Mixto')) {
      sectionSimple.style.display = 'none';
      sectionMixed.style.display = 'block';

      const [group1, group2] = getMixedGroups(selectedFood.grupo);
      mixedInfo.textContent = `Este alimento es mixto. Puedes intercambiar por ½ ración de ${group1} + ½ ración de ${group2}.`;
      exchangeLabel1.textContent = `${group1} (½ ración)`;
      exchangeLabel2.textContent = `${group2} (½ ración)`;

      mixed1Search.items = foods.filter(f => f.grupo === group1).map(f => ({ value: f.alimento, label: f.alimento }));
      mixed1Search.value = '';
      mixed1Search.input.value = '';
      mixed1Search.input.placeholder = 'Buscar alimento...';
      mixed1Search.input.disabled = false;

      mixed2Search.items = foods.filter(f => f.grupo === group2).map(f => ({ value: f.alimento, label: f.alimento }));
      mixed2Search.value = '';
      mixed2Search.input.value = '';
      mixed2Search.input.placeholder = 'Buscar alimento...';
      mixed2Search.input.disabled = false;

      resultMixed1.style.display = 'none';
      resultMixed2.style.display = 'none';
    } else {
      sectionSimple.style.display = 'block';
      sectionMixed.style.display = 'none';

      exchangeSearch.items = foods.filter(f => f.grupo === selectedFood.grupo).map(f => ({ value: f.alimento, label: f.alimento }));
      exchangeSearch.value = '';
      exchangeSearch.input.value = '';
      exchangeSearch.input.placeholder = 'Buscar intercambio...';
      exchangeSearch.input.disabled = false;
      resultSimple.style.display = 'none';
    }
  }

  function getMixedGroups(grupo) {
    if (grupo === 'Mixto (P+H)') return ['Proteína', 'Hidratos'];
    if (grupo === 'Mixto (P+G)') return ['Proteína', 'Grasas'];
    return [];
  }

  // --- Calculation ---
  function calculateAndDisplay() {
    const selectedFood = getSelectedFood();
    const quantity = parseFloat(quantityInput.value);

    if (!selectedFood || !quantity || quantity <= 0) return;

    if (selectedFood.grupo.startsWith('Mixto')) {
      calculateMixed(selectedFood, quantity);
    } else {
      calculateSimple(selectedFood, quantity);
    }
  }

  function calculateSimple(selectedFood, quantity) {
    const exchangeName = exchangeSearch.value;
    if (!exchangeName) {
      resultSimple.style.display = 'none';
      return;
    }

    const exchangeFood = foods.find(f => f.alimento === exchangeName);
    if (!exchangeFood) return;

    const ratio = quantity / selectedFood.cantidadBase;
    const result = Math.round(ratio * exchangeFood.cantidadBase * 10) / 10;

    resultValue.textContent = result;
    resultUnit.textContent = exchangeFood.unidad;
    resultSimple.style.display = 'flex';
  }

  function calculateMixed(selectedFood, quantity) {
    const exchange1Name = mixed1Search.value;
    const exchange2Name = mixed2Search.value;
    const ratio = quantity / selectedFood.cantidadBase;

    if (exchange1Name) {
      const food1 = foods.find(f => f.alimento === exchange1Name);
      if (food1) {
        const result1 = Math.round(ratio * food1.cantidadBase * 0.5 * 10) / 10;
        resultValue1.textContent = result1;
        resultUnit1.textContent = food1.unidad;
        resultMixed1.style.display = 'flex';
      }
    } else {
      resultMixed1.style.display = 'none';
    }

    if (exchange2Name) {
      const food2 = foods.find(f => f.alimento === exchange2Name);
      if (food2) {
        const result2 = Math.round(ratio * food2.cantidadBase * 0.5 * 10) / 10;
        resultValue2.textContent = result2;
        resultUnit2.textContent = food2.unidad;
        resultMixed2.style.display = 'flex';
      }
    } else {
      resultMixed2.style.display = 'none';
    }
  }

  quantityInput.addEventListener('input', calculateAndDisplay);
</script>

<style>
  .calculator {
    padding: 2rem 1.5rem 4rem;
    max-width: 640px;
    margin: 0 auto;
  }

  .calculator-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .filter-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-beige);
    border-radius: 20px;
    background: var(--color-white);
    color: var(--color-dark-brown);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    background: var(--color-light-gray);
  }

  .filter-btn.active {
    background: var(--color-dark-brown);
    color: var(--color-gold);
    border-color: var(--color-dark-brown);
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-dark-brown);
  }

  .card {
    background: var(--color-white);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 8px rgba(76, 58, 47, 0.06);
    border: 1px solid rgba(223, 201, 177, 0.3);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .form-group:last-child {
    margin-bottom: 0;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  label {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-dark-brown);
    opacity: 0.7;
  }

  .searchable-select {
    position: relative;
  }

  .search-input {
    width: 100%;
    background: var(--color-light-gray);
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 0.75rem 2.5rem 0.75rem 1rem;
    font-size: 0.9rem;
    color: var(--color-dark);
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-beige);
  }

  .search-input:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .search-clear {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border: none;
    background: var(--color-beige);
    border-radius: 50%;
    font-size: 1rem;
    line-height: 1;
    color: var(--color-dark-brown);
    cursor: pointer;
    transition: background 0.15s;
  }

  .search-clear:hover {
    background: var(--color-dark-brown);
    color: var(--color-white);
  }

  .search-options {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    margin: 0;
    padding: 0.5rem 0;
    list-style: none;
    background: var(--color-white);
    border: 1px solid var(--color-beige);
    border-radius: 8px;
    box-shadow: 0 4px 12px rgba(76, 58, 47, 0.12);
    max-height: 200px;
    overflow-y: auto;
    z-index: 100;
  }

  .search-option {
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    color: var(--color-dark);
    cursor: pointer;
    transition: background 0.15s;
    border-bottom: 1px solid rgba(223, 201, 177, 0.2);
  }

  .search-option:last-child {
    border-bottom: none;
  }

  .search-option:hover {
    background: var(--color-light-gray);
  }

  .search-option.selected {
    background: var(--color-beige);
    font-weight: 500;
  }

  .search-option-empty {
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    color: var(--color-dark-brown);
    opacity: 0.5;
    font-style: italic;
  }

  .input-with-unit {
    display: flex;
    align-items: center;
    background: var(--color-light-gray);
    border-radius: 8px;
    border: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .input-with-unit:focus-within {
    border-color: var(--color-beige);
  }

  input[type="number"] {
    flex: 1;
    background: transparent;
    border: none;
    padding: 0.75rem 0.5rem 0.75rem 1rem;
    font-size: 0.9rem;
    color: var(--color-dark);
    min-width: 0;
  }

  input[type="number"]:focus {
    outline: none;
  }

  input[type="number"]::-webkit-inner-spin-button,
  input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none;
  }

  .unit-label {
    padding: 0.75rem 1rem 0.75rem 0.25rem;
    font-size: 0.85rem;
    color: var(--color-dark-brown);
    opacity: 0.6;
    font-weight: 500;
  }

  .group-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    background: var(--color-light-gray);
    color: var(--color-dark-brown);
  }

  .badge-hidratos {
    background: #E8F0E4;
    color: #3D5A3A;
  }

  .badge-protena {
    background: #FCE8E8;
    color: #7A3030;
  }

  .badge-grasas {
    background: #FFF3E0;
    color: #7A5020;
  }

  .badge-mixtoph {
    background: #E8E0F8;
    color: #4A3070;
  }

  .badge-mixtopg {
    background: #E0EFF8;
    color: #2A4A6A;
  }

  .divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    color: var(--color-beige);
  }

  .mixed-info {
    font-size: 0.85rem;
    color: var(--color-dark-brown);
    opacity: 0.7;
    margin-bottom: 1rem;
    padding: 0.75rem;
    background: var(--color-light-gray);
    border-radius: 8px;
    line-height: 1.5;
  }

  .result {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 1rem;
    background: var(--color-dark-brown);
    border-radius: 8px;
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .result-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gold);
    opacity: 0.7;
  }

  .result-value {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-gold);
  }

  .result-unit {
    font-size: 0.9rem;
    color: var(--color-gold);
    opacity: 0.7;
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .calculator {
      padding: 1.5rem 1rem 3rem;
    }
  }
</style>
